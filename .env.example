# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=mastery_hub

# Server
PORT=8080
LOG_LEVEL=info

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend
FRONTEND_URL=http://localhost:5173

# AI Tutor (optional - defaults to Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Code Sandbox
SANDBOX_TIMEOUT=30s
SANDBOX_MEMORY=128m

# Content
CONTENT_DIR=./content
