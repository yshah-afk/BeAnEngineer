# =============================================================================
# AI & Full-Stack Mastery Hub — Backend Environment Variables
# =============================================================================
# Copy this file to .env and update with your values.
# All variables with defaults can be omitted for local development.

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=mastery_hub

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8080
LOG_LEVEL=info          # debug | info | warn | error

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_TTL=15m      # Access token lifetime
JWT_REFRESH_TTL=168h    # Refresh token lifetime (7 days)

# -----------------------------------------------------------------------------
# OAuth — GitHub
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# OAuth — Google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Frontend (CORS & OAuth redirects)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# AI Tutor — Ollama (default, local)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# -----------------------------------------------------------------------------
# AI Tutor — OpenAI-compatible (overrides Ollama when OPENAI_API_KEY is set)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# Code Playground Sandbox
# -----------------------------------------------------------------------------
SANDBOX_TIMEOUT=30s
SANDBOX_MEMORY=128m

# -----------------------------------------------------------------------------
# Content Directory (relative to backend binary)
# -----------------------------------------------------------------------------
CONTENT_DIR=../content
